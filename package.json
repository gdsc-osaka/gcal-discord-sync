{
  "name": "gcal-to-discord-scheduled-event",
  "version": "0.1.0",
  "description": "Sync Google Calendar events to Discord Guild Scheduled Events, with live status (ACTIVE/COMPLETED/CANCELED) reflected on Discord. Runs on Google Apps Script.",
  "private": true,
  "scripts": {
    "build": "webpack",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "push": "npm run build && clasp push",
    "deploy": "npm run build && clasp push && clasp deploy"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "gas-webpack-plugin": "^2.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
